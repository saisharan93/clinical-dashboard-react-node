{
    "name": "clinical-dashboard-api",
    "version": "1.0.0",
    "type": "module",
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "dev": "nodemon src/index.js",
        "client:dev": "npm --prefix client run dev",
        "client:build": "npm --prefix client run build",
        "client:preview": "npm --prefix client run preview",
        "dev:all": "concurrently \"npm run dev\" \"npm run client:dev\""
      },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.19.2"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "nodemon": "^3.1.0"
    }
}
